# OAuth (Client) – exposed to browser by Vite
# Must be an absolute URL including http/https (e.g. https://auth.example.com)
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=

# OAuth (Server)
OAUTH_SERVER_URL=

# Server
PORT=3000
DATABASE_URL=mysql://user:password@localhost:3306/pte_practice
JWT_SECRET=your-secret-min-32-chars

# Optional: set this openId to grant admin role to a user after first login
OWNER_OPEN_ID=

# Optional: AI/Forge
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=

