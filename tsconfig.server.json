  "compilerOptions": {
    "moduleResolution": "node",
    "module": "commonjs",
    "allowImportingTsExtensions": false,
    "noEmit": true,
    "skipLibCheck": true,
    "strict": false
  },
  "include": ["api/**/*", "server/**/*", "shared/**/*", "drizzle/**/*"]
}
